<%layout('/layouts/boilerplate')%>
<div class="row mt-3">
    <div class="col-8 offset-2">
        <body>
            <h1>Update Your Property</h1>
            <form method="post" action="/listing/<%=listing._id%>?_method=PUT" novalidate class="needs-validation">
            <div class="mb-3">
                <label for="title" class="form-label">Enter Updated Title</label>
                <input type="text" required name="listing[title]" class="form-control" value="<%=listing.title%>">
                <div class="invalid-feedback">
                    Title should be valid
                </div>
                <div class="valid-feedback">
                    Title Looks Good!
                </div>
            </div>
            <div class="mb-3">
                <label for="description" class="form-label">Enter New Description</label>
                <textarea required name="listing[description]" class="form-control"><%= listing.description %></textarea>
                <div class="invalid-feedback">
                    Description should be valid
                </div>
                <div class="valid-feedback">
                    Description Looks Good!
                </div>
            </div>
            <div class="mb-3">
                <label for="image" class="form-label">Enter new IMAGE LINK</label>
                <input required name="listing[image][url]" type="text" class="form-control" value="<%=listing.image.url%>">
                <div class="invalid-feedback">
                    Plz enter valid link
                </div>
                <div class="valid-feedback">
                    Image looks Good!!
                </div>
            </div>
            <div class="row">
                <div class="mb-3 col-md-4">
                    <label for="price" class="form-label">Enter New Price</label>
                    <input required type="number" name="listing[price]" class="form-control" value="<%=listing.price%>">
                    <div class="invalid-feedback">
                        Price should be valid
                    </div>
                    <div class="valid-feedback">
                        Price Looks Good!
                    </div>
                </div>
                <div class="mb-3 col-md-4">
                    <label for="country" class="form-label">Enter New Country</label>
                    <input required type="text" name="listing[country]" class="form-control" value="<%=listing.country%>">
                    <div class="invalid-feedback">
                        COuntry should be valid
                    </div>
                    <div class="valid-feedback">
                        Country Looks Good!
                    </div>
                </div>
            </div>
            
            <div class="mb-3">
                <label for="location" class="form-label">Enter Updated Location</label>
                <input required type="text" name="listing[location]" class="form-control" value="<%=listing.location%>">
                <div class="invalid-feedback">
                    Location should be valid
                </div>
                <div class="valid-feedback">
                    Location Looks Good!
                </div>
            </div>
            <div class="mb-3 mt-3">
                <button type="submit" class="btn">Update</button>
            </div>
            </form>
        </body>
        
    </div>
</div>
